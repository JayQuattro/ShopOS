generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CustomerKind {
  INDIVIDUAL @map("individual")
  BUSINESS   @map("business")

  @@map("customer_kind")
}

enum AssetStatus {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")
  SOLD     @map("sold")
  ARCHIVED @map("archived")

  @@map("asset_status")
}

enum WorkType {
  REPAIR      @map("repair")
  MAINTENANCE @map("maintenance")
  PROJECT     @map("project")

  @@map("work_type")
}

enum WorkOrderStatus {
  DRAFT                  @map("draft")
  ESTIMATING             @map("estimating")
  AWAITING_AUTHORIZATION @map("awaiting_authorization")
  AUTHORIZED             @map("authorized")
  IN_PROGRESS            @map("in_progress")
  BLOCKED                @map("blocked")
  COMPLETED              @map("completed")
  INVOICED               @map("invoiced")
  CLOSED                 @map("closed")
  CANCELLED              @map("cancelled")

  @@map("work_order_status")
}

enum EstimateRevisionStatus {
  DRAFT      @map("draft")
  PRESENTED  @map("presented")
  SUPERSEDED @map("superseded")
  EXPIRED    @map("expired")

  @@map("estimate_revision_status")
}

enum PricedLineKind {
  LABOR @map("labor")
  PART  @map("part")
  FEE   @map("fee")

  @@map("priced_line_kind")
}

enum AuthorizationDecisionValue {
  APPROVED @map("approved")
  DECLINED @map("declined")

  @@map("authorization_decision")
}

enum AuthorizationMethod {
  CUSTOMER_LINK @map("customer_link")
  PHONE         @map("phone")
  IN_PERSON     @map("in_person")
  EMAIL         @map("email")
  OTHER         @map("other")

  @@map("authorization_method")
}

enum InvoiceStatus {
  DRAFT          @map("draft")
  ISSUED         @map("issued")
  PARTIALLY_PAID @map("partially_paid")
  PAID           @map("paid")
  VOID           @map("void")

  @@map("invoice_status")
}

enum PaymentMethod {
  CASH          @map("cash")
  CARD_EXTERNAL @map("card_external")
  CHECK         @map("check")
  BANK_TRANSFER @map("bank_transfer")
  OTHER         @map("other")

  @@map("payment_method")
}

enum OrganizationStatus {
  PROVISIONING @map("provisioning")
  ACTIVE       @map("active")
  SUSPENDED    @map("suspended")
  CLOSED       @map("closed")

  @@map("organization_status")
}

enum SubscriptionState {
  UNMANAGED @map("unmanaged")
  TRIALING  @map("trialing")
  ACTIVE    @map("active")
  PAST_DUE  @map("past_due")
  CANCELED  @map("canceled")

  @@map("subscription_state")
}

enum PlatformOperatorRole {
  VIEWER   @map("viewer")
  OPERATOR @map("operator")
  ADMIN    @map("admin")

  @@map("platform_operator_role")
}

enum ProvisioningActorKind {
  SELF_SERVICE      @map("self_service")
  PLATFORM_OPERATOR @map("platform_operator")
  SYSTEM            @map("system")

  @@map("provisioning_actor_kind")
}

model User {
  id                     String                            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                  String                            @unique(map: "users_email_unique") @db.VarChar(320)
  displayName            String                            @map("display_name") @db.VarChar(160)
  emailVerified          Boolean                           @default(false) @map("email_verified")
  image                  String?                           @db.VarChar(2048)
  twoFactorEnabled       Boolean                           @default(false) @map("two_factor_enabled")
  disabledAt             DateTime?                         @map("disabled_at") @db.Timestamptz(6)
  createdAt              DateTime                          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                          @updatedAt @map("updated_at") @db.Timestamptz(6)
  authSessions           AuthSession[]
  authAccounts           AuthAccount[]
  organizationInvites    OrganizationInvitation[]          @relation("OrganizationInvitationInviter")
  twoFactors             TwoFactor[]
  passkeys               Passkey[]
  ssoProviders           OrganizationSsoProvider[]         @relation("SsoProviderCreator")
  memberships            OrganizationMembership[]
  createdEstimates       EstimateRevision[]                @relation("EstimateCreatedBy")
  recordedAuthorizations Authorization[]                   @relation("AuthorizationRecordedBy")
  recordedPayments       Payment[]                         @relation("PaymentRecordedBy")
  activityEvents         ActivityEvent[]                   @relation("ActivityActor")
  auditEvents            AuditEvent[]                      @relation("AuditActor")
  themePublications      OrganizationThemePublication[]    @relation("ThemePublishedBy")
  platformOperatorGrants PlatformOperatorGrant[]           @relation("PlatformOperatorGrantUser")
  platformGrantsGiven    PlatformOperatorGrant[]           @relation("PlatformOperatorGrantGrantedBy")
  platformGrantsRevoked  PlatformOperatorGrant[]           @relation("PlatformOperatorGrantRevokedBy")
  platformAuditEvents    PlatformAuditEvent[]              @relation("PlatformAuditActor")
  provisioningRequests   OrganizationProvisioningRequest[] @relation("ProvisioningActor")
  entitlementUpdates     OrganizationEntitlement[]         @relation("EntitlementUpdatedBy")

  @@map("users")
}

model Organization {
  id                  String                           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                String                           @unique @db.VarChar(80)
  name                String                           @db.VarChar(180)
  logoUrl             String?                          @map("logo_url") @db.VarChar(2048)
  authMetadata        String?                          @map("auth_metadata")
  status              OrganizationStatus               @default(ACTIVE)
  defaultCurrency     String                           @default("USD") @map("default_currency") @db.VarChar(3)
  subscriptionState   SubscriptionState                @default(UNMANAGED) @map("subscription_state")
  createdAt           DateTime                         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                         @updatedAt @map("updated_at") @db.Timestamptz(6)
  locations           Location[]
  memberships         OrganizationMembership[]
  invitations         OrganizationInvitation[]
  activeSessions      AuthSession[]                    @relation("ActiveOrganization")
  ssoProviders        OrganizationSsoProvider[]
  roles               Role[]
  membershipRoles     MembershipRole[]
  locationAccess      LocationAccess[]
  customers           Customer[]
  assets              Asset[]
  workOrders          WorkOrder[]
  estimateRevisions   EstimateRevision[]
  estimateLines       EstimateLine[]
  authorizations      Authorization[]
  authDecisions       AuthorizationDecision[]
  invoices            Invoice[]
  invoiceLines        InvoiceLine[]
  payments            Payment[]
  activityEvents      ActivityEvent[]
  auditEvents         AuditEvent[]
  platformAuditEvents PlatformAuditEvent[]
  provisioningRequest OrganizationProvisioningRequest?
  entitlements        OrganizationEntitlement[]
  outboxEvents        OutboxEvent[]
  themePublications   OrganizationThemePublication[]
  customerContacts    CustomerContact[]
  customerAddresses   CustomerAddress[]

  @@map("organizations")
}

model OrganizationThemePublication {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  version          Int
  preset           String   @db.VarChar(24)
  accentHue        Int?     @map("accent_hue")
  radiusScale      String   @default("standard") @map("radius_scale") @db.VarChar(12)
  densityDefault   String   @default("comfortable") @map("density_default") @db.VarChar(12)
  logoUrl          String?  @map("logo_url") @db.VarChar(2048)
  publishedByUserId String  @map("published_by_user_id") @db.Uuid
  publishedAt      DateTime @default(now()) @map("published_at") @db.Timestamptz(6)
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  publishedBy      User     @relation("ThemePublishedBy", fields: [publishedByUserId], references: [id], onDelete: Restrict)

  @@unique([organizationId, version], map: "theme_publications_org_version_unique")
  @@index([organizationId, version], map: "theme_publications_org_version_idx")
  @@map("organization_theme_publications")
}

model Location {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  code           String             @db.VarChar(32)
  name           String             @db.VarChar(180)
  timeZone       String             @map("time_zone") @db.VarChar(80)
  active         Boolean            @default(true)
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  accessGrants   LocationAccess[]
  homeAssets     Asset[]
  workOrders     WorkOrder[]
  estimates      EstimateRevision[]
  invoices       Invoice[]
  payments       Payment[]
  activityEvents ActivityEvent[]
  auditEvents    AuditEvent[]

  @@unique([organizationId, code], map: "locations_org_code_unique")
  @@unique([organizationId, id], map: "locations_org_id_unique")
  @@index([organizationId], map: "locations_org_idx")
  @@map("locations")
}

model OrganizationMembership {
  id                             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId                 String           @map("organization_id") @db.Uuid
  userId                         String           @map("user_id") @db.Uuid
  organizationWideLocationAccess Boolean          @default(false) @map("organization_wide_location_access")
  authRole                       String           @default("member") @map("auth_role") @db.VarChar(255)
  active                         Boolean          @default(true)
  themePreference                String           @default("system") @map("theme_preference") @db.VarChar(12)
  densityPreference              String           @default("comfortable") @map("density_preference") @db.VarChar(12)
  createdAt                      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization                   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  roles                          MembershipRole[]
  locationAccess                 LocationAccess[]

  @@unique([organizationId, userId], map: "memberships_org_user_unique")
  @@unique([organizationId, id], map: "memberships_org_id_unique")
  @@index([userId], map: "memberships_user_idx")
  @@map("organization_memberships")
}

model PlatformOperatorGrant {
  id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String               @map("user_id") @db.Uuid
  role             PlatformOperatorRole
  reason           String               @db.VarChar(500)
  grantedByUserId  String?              @map("granted_by_user_id") @db.Uuid
  expiresAt        DateTime?            @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime?            @map("revoked_at") @db.Timestamptz(6)
  revokedByUserId  String?              @map("revoked_by_user_id") @db.Uuid
  revocationReason String?              @map("revocation_reason") @db.VarChar(500)
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User                 @relation("PlatformOperatorGrantUser", fields: [userId], references: [id], onDelete: Restrict)
  grantedBy        User?                @relation("PlatformOperatorGrantGrantedBy", fields: [grantedByUserId], references: [id], onDelete: Restrict)
  revokedBy        User?                @relation("PlatformOperatorGrantRevokedBy", fields: [revokedByUserId], references: [id], onDelete: Restrict)

  @@index([userId, revokedAt, expiresAt], map: "platform_operator_grants_active_idx")
  @@map("platform_operator_grants")
}

model PlatformAuditEvent {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId          String?       @map("actor_user_id") @db.Uuid
  targetOrganizationId String?       @map("target_organization_id") @db.Uuid
  action               String        @db.VarChar(120)
  targetType           String        @map("target_type") @db.VarChar(80)
  targetId             String        @map("target_id") @db.VarChar(160)
  requestId            String?       @map("request_id") @db.VarChar(120)
  reason               String?       @db.VarChar(500)
  metadata             Json?
  occurredAt           DateTime      @default(now()) @map("occurred_at") @db.Timestamptz(6)
  actor                User?         @relation("PlatformAuditActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  targetOrganization   Organization? @relation(fields: [targetOrganizationId], references: [id], onDelete: Restrict)

  @@index([targetOrganizationId, occurredAt], map: "platform_audit_org_time_idx")
  @@index([actorUserId, occurredAt], map: "platform_audit_actor_time_idx")
  @@map("platform_audit_events")
}

model OrganizationProvisioningRequest {
  id             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId    String                @map("actor_user_id") @db.Uuid
  actorKind      ProvisioningActorKind @map("actor_kind")
  idempotencyKey String                @map("idempotency_key") @db.VarChar(160)
  inputHash      String                @map("input_hash") @db.Char(64)
  organizationId String                @unique(map: "provisioning_requests_org_unique") @map("organization_id") @db.Uuid
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt    DateTime              @default(now()) @map("completed_at") @db.Timestamptz(6)
  actor          User                  @relation("ProvisioningActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@unique([actorUserId, idempotencyKey], map: "provisioning_requests_actor_key_unique")
  @@map("organization_provisioning_requests")
}

model OrganizationEntitlement {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  key             String       @db.VarChar(120)
  enabled         Boolean      @default(true)
  limitValue      BigInt?      @map("limit_value")
  configuration   Json?
  source          String       @default("platform") @db.VarChar(80)
  effectiveAt     DateTime     @default(now()) @map("effective_at") @db.Timestamptz(6)
  expiresAt       DateTime?    @map("expires_at") @db.Timestamptz(6)
  updatedByUserId String?      @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  updatedBy       User?        @relation("EntitlementUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Restrict)

  @@unique([organizationId, key], map: "organization_entitlements_org_key_unique")
  @@index([organizationId, enabled], map: "organization_entitlements_org_enabled_idx")
  @@map("organization_entitlements")
}

model OutboxEvent {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  eventType      String       @map("event_type") @db.VarChar(120)
  aggregateType  String       @map("aggregate_type") @db.VarChar(80)
  aggregateId    String       @map("aggregate_id") @db.Uuid
  payload        Json
  occurredAt     DateTime     @default(now()) @map("occurred_at") @db.Timestamptz(6)
  availableAt    DateTime     @default(now()) @map("available_at") @db.Timestamptz(6)
  publishedAt    DateTime?    @map("published_at") @db.Timestamptz(6)
  attempts       Int          @default(0)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([publishedAt, availableAt], map: "outbox_unpublished_available_idx")
  @@index([organizationId, occurredAt], map: "outbox_org_time_idx")
  @@map("outbox_events")
}

model AuthSession {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String        @map("user_id") @db.Uuid
  activeOrganizationId String?       @map("active_organization_id") @db.Uuid
  token                String        @unique(map: "auth_sessions_token_unique") @db.VarChar(255)
  expiresAt            DateTime      @map("expires_at") @db.Timestamptz(6)
  ipAddress            String?       @map("ip_address") @db.VarChar(64)
  userAgent            String?       @map("user_agent")
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganization   Organization? @relation("ActiveOrganization", fields: [activeOrganizationId], references: [id], onDelete: SetNull)

  @@index([userId], map: "auth_sessions_user_idx")
  @@index([activeOrganizationId], map: "auth_sessions_active_org_idx")
  @@map("auth_sessions")
}

model AuthAccount {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String    @map("user_id") @db.Uuid
  accountId             String    @map("account_id") @db.VarChar(255)
  providerId            String    @map("provider_id") @db.VarChar(255)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamptz(6)
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamptz(6)
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId], map: "auth_accounts_provider_account_unique")
  @@index([userId], map: "auth_accounts_user_idx")
  @@map("auth_accounts")
}

model AuthVerification {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identifier String   @db.VarChar(255)
  value      String
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([identifier], map: "auth_verifications_identifier_idx")
  @@index([expiresAt], map: "auth_verifications_expires_idx")
  @@map("auth_verifications")
}

model OrganizationInvitation {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  inviterId      String       @map("inviter_id") @db.Uuid
  email          String       @db.VarChar(320)
  role           String?      @db.VarChar(255)
  status         String       @default("pending") @db.VarChar(32)
  expiresAt      DateTime     @map("expires_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter        User         @relation("OrganizationInvitationInviter", fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId, status], map: "org_invitations_org_status_idx")
  @@index([email], map: "org_invitations_email_idx")
  @@index([expiresAt], map: "org_invitations_expires_idx")
  @@map("organization_invitations")
}

model TwoFactor {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                  String    @map("user_id") @db.Uuid
  secret                  String
  backupCodes             String    @map("backup_codes")
  verified                Boolean   @default(true)
  failedVerificationCount Int       @default(0) @map("failed_verification_count")
  lockedUntil             DateTime? @map("locked_until") @db.Timestamptz(6)
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret], map: "two_factors_secret_idx")
  @@index([userId], map: "two_factors_user_idx")
  @@map("auth_two_factors")
}

model Passkey {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  name         String?   @db.VarChar(160)
  publicKey    String    @map("public_key")
  credentialID String    @unique(map: "passkeys_credential_id_unique") @map("credential_id")
  counter      Int
  deviceType   String    @map("device_type") @db.VarChar(32)
  backedUp     Boolean   @map("backed_up")
  transports   String?
  aaguid       String?   @db.VarChar(64)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "passkeys_user_idx")
  @@map("auth_passkeys")
}

model OrganizationSsoProvider {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  providerId     String       @unique(map: "sso_providers_provider_id_unique") @map("provider_id") @db.VarChar(191)
  issuer         String       @db.VarChar(2048)
  domain         String       @db.VarChar(2048)
  domainVerified Boolean      @default(false) @map("domain_verified")
  oidcConfig     String?      @map("oidc_config")
  samlConfig     String?      @map("saml_config")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User         @relation("SsoProviderCreator", fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId], map: "sso_providers_org_idx")
  @@index([userId], map: "sso_providers_user_idx")
  @@index([domain], map: "sso_providers_domain_idx")
  @@map("organization_sso_providers")
}

model Role {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String           @map("organization_id") @db.Uuid
  key             String           @db.VarChar(64)
  name            String           @db.VarChar(120)
  permissions     Json             @default("[]")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  membershipRoles MembershipRole[]

  @@unique([organizationId, key], map: "roles_org_key_unique")
  @@unique([organizationId, id], map: "roles_org_id_unique")
  @@map("roles")
}

model MembershipRole {
  organizationId String                 @map("organization_id") @db.Uuid
  membershipId   String                 @map("membership_id") @db.Uuid
  roleId         String                 @map("role_id") @db.Uuid
  createdAt      DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  membership     OrganizationMembership @relation(fields: [organizationId, membershipId], references: [organizationId, id], onDelete: Cascade)
  role           Role                   @relation(fields: [organizationId, roleId], references: [organizationId, id], onDelete: Cascade)

  @@id([membershipId, roleId])
  @@map("membership_roles")
}

model LocationAccess {
  organizationId String                 @map("organization_id") @db.Uuid
  membershipId   String                 @map("membership_id") @db.Uuid
  locationId     String                 @map("location_id") @db.Uuid
  createdAt      DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  membership     OrganizationMembership @relation(fields: [organizationId, membershipId], references: [organizationId, id], onDelete: Cascade)
  location       Location               @relation(fields: [organizationId, locationId], references: [organizationId, id], onDelete: Cascade)

  @@id([membershipId, locationId])
  @@map("location_access")
}

model Customer {
  id                    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId        String       @map("organization_id") @db.Uuid
  kind                  CustomerKind
  displayName           String       @map("display_name") @db.VarChar(220)
  organizationReference String?      @map("organization_reference") @db.VarChar(64)
  primaryEmail          String?      @map("primary_email") @db.VarChar(320)
  primaryPhone          String?      @map("primary_phone") @db.VarChar(40)
