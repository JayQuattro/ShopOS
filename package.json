{
  "name": "shopos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Open-source, SaaS-first shop operations platform",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11 <12"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:format": "prisma format",
    "db:validate": "prisma validate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "worker": "tsx scripts/run-worker.ts",
    "platform:bootstrap-operator": "tsx scripts/bootstrap-platform-operator.ts",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm db:validate && pnpm test"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.6.0",
    "@better-auth/prisma-adapter": "^1.6.0",
    "@better-auth/sso": "^1.6.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@radix-ui/react-avatar": "^1.2.4",
    "@radix-ui/react-dialog": "^1.1.21",
    "@radix-ui/react-dropdown-menu": "^2.1.22",
    "@radix-ui/react-separator": "^1.1.13",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.19",
    "better-auth": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.0.0",
    "lucide-react": "^1.25.0",
    "next": "16.2.11",
    "pg": "^8.16.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/culori": "^4.0.1",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "culori": "^4.0.2",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.11",
    "jsdom": "^29.1.1",
    "prettier": "^3.6.0",
    "prisma": "^7.7.0",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}
