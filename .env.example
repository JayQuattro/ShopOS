DATABASE_URL=postgres://shopos:shopos@localhost:5432/shopos
APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters

# Auth message delivery. "console" captures messages in dev/test (never sends real email);
# "none" is the safe production default when no real provider is configured yet.
AUTH_EMAIL_DELIVERY=console

# Throwaway PostgreSQL database for auth integration tests. Defaults to the compose `shopos_test`
# database; the suite skips cleanly when Postgres is unreachable.
SHOPOS_TEST_DATABASE_URL=postgres://shopos:shopos@localhost:5432/shopos_test

# Optional platform-wide sign-in. These authenticate identity but never grant organization membership.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Optional bot protection; the application must remain usable without this in self-hosted deployments.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
LOG_LEVEL=info

# Background worker (outbox dispatcher). Run as a separate process with `pnpm worker`.
OUTBOX_POLL_INTERVAL_MS=3000
OUTBOX_BATCH_SIZE=50
