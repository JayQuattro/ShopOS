DATABASE_URL=postgres://shopos:shopos@localhost:5432/shopos
APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters

# Optional platform-wide sign-in. These authenticate identity but never grant organization membership.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Optional bot protection; the application must remain usable without this in self-hosted deployments.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
LOG_LEVEL=info
